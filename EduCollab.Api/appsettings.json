{
  "Database": {
    "ConnectionString": "Host=db;Port=5432;Database=EduCollab;Username=postgres;Password=postgres;"
  },
  "Jwt": {
    "Issuer": "EduCollab.Api",
    "Audience": "EduCollab.Client",
    "SecretKey": "replace-this-with-a-long-dev-secret-key",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 14
  },
  "PasswordReset": {
    "TokenExpirationMinutes": 3,
    "LogPlaintextTokenInDevelopment": false
  },
  "EmailConfirmation": {
    "TokenExpirationHours": 24,
    "FrontendConfirmUrl": "https://localhost:3000/auth/confirm-email",
    "LogPlaintextTokenInDevelopment": false
  },
  "LoginCode": {
    "CodeExpirationMinutes": 3,
    "LogPlaintextCodeInDevelopment": false,
    "MaxAttempts": 3
  },
  "WorkspaceInvitation": {
    "TokenExpirationHours": 168,
    "FrontendAcceptUrl": "https://localhost:3000/workspace/join",
    "LogPlaintextTokenInDevelopment": false
  },
  "Email": {
    "Enabled": false,
    "SmtpHost": "",
    "SmtpPort": 587,
    "UseSsl": true,
    "UserName": "",
    "Password": "",
    "FromAddress": "noreply@localhost",
    "FromDisplayName": "EduCollab"
  },
  "UserPreferencesStorage": {
    "RootPath": "App_Data/UserPreferences"
  },
  "WorkspaceThumbnailStorage": {
    "RootPath": "App_Data/WorkspaceThumbnails"
  },
  "WorkspaceContentStorage": {
    "RootPath": "App_Data/Content",
    "MaxAssetBytes": 104857600,
    "MaxSceneJsonBytes": 10485760
  },
  "WorkspaceCreationApproval": {
    "TokenExpirationHours": 168,
    "FrontendCreateUrl": "https://localhost:3000/workspace/create",
    "AdminReviewUrlBase": "http://localhost:8080/api/workspace-creation-review",
    "AdminReviewTokenExpirationHours": 168,
    "LogPlaintextTokenInDevelopment": false
  },
  "PlatformAdmin": {
    "Email": "admin@educollab.local",
    "Password": "Admin123!"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
