{
  "Database": {
    "ConnectionString": "Server=localhost;Port=5432;Database=EduCollab;User Id=postgres;Password=postgres;"
  },
  "Jwt": {
    "Issuer": "EduCollab.Api",
    "Audience": "EduCollab.Client",
    "SecretKey": "replace-this-with-a-long-dev-secret-key",
    "ExpirationMinutes": 60
  },
  "PasswordReset": {
    "TokenExpirationHours": 24,
    "LogPlaintextTokenInDevelopment": true
  },
  "EmailConfirmation": {
    "TokenExpirationHours": 24,
    "FrontendConfirmUrl": "http://localhost:3000/auth/confirm-email",
    "LogPlaintextTokenInDevelopment": true
  },
  "LoginCode": {
    "CodeExpirationMinutes": 10,
    "LogPlaintextCodeInDevelopment": true,
    "MaxAttempts": 3
  },
  "Email": {
    "Enabled": true,
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "UseSsl": false,
    "UserName": "",
    "Password": "",
    "FromAddress": "noreply@educollab.local",
    "FromDisplayName": "EduCollab (dev)"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
